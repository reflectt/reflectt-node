# reflectt-node Starter — environment template
# Copy to .env and fill in your values:
#   cp .env.starter .env

# ── LLM API key (required for agents to respond) ──
# Provide at least one. Anthropic Claude is recommended.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Cloud connection (fill in after signing up at app.reflectt.ai) ──
# Leave blank to run standalone (local dashboard only, no presence sync).
REFLECTT_CLOUD_URL=https://app.reflectt.ai
REFLECTT_HOST_ID=
REFLECTT_HOST_CREDENTIAL=
REFLECTT_HOST_NAME=my-team

# ── Local STT (optional — avoids OpenAI API key for voice) ──
# reflectt-node auto-detects the whisper binary via PATH and `brew --prefix openai-whisper`.
# Set LOCAL_WHISPER_BIN to pin an explicit path (useful if whisper is installed in an
# unusual location or after a `brew upgrade openai-whisper` changes the keg directory).
# LOCAL_WHISPER_BIN=/path/to/whisper
# LOCAL_WHISPER_MODEL=tiny   # tiny | base | small (default: tiny)

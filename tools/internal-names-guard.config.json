{
  "includePrefixes": ["public/", "src/", "templates/"],
  "excludePrefixes": [
    "src/__tests__/",
    "tests/",
    "dist/",
    "node_modules/",
    "process/"
  ],
  "banned": [
    { "pattern": "\\bRyan\\b", "flags": "g", "reason": "Internal proper noun" },
    { "pattern": "\\bKai\\b", "flags": "g", "reason": "Internal proper noun" },
    { "pattern": "\\bSage\\b", "flags": "g", "reason": "Internal proper noun" },
    { "pattern": "\\bPixel\\b", "flags": "g", "reason": "Internal proper noun" },
    { "pattern": "\\bLink\\b", "flags": "g", "reason": "Internal proper noun (may be false-positive; use allowlist)" },
    { "pattern": "\\bEcho\\b", "flags": "g", "reason": "Internal proper noun" },
    { "pattern": "\\bRhythm\\b", "flags": "g", "reason": "Internal proper noun" },
    { "pattern": "\\bScout\\b", "flags": "g", "reason": "Internal proper noun" },
    { "pattern": "\\bSpark\\b", "flags": "g", "reason": "Internal proper noun" },
    { "pattern": "\\bHarmony\\b", "flags": "g", "reason": "Internal proper noun" },

    { "pattern": "reflectt\\.ai", "flags": "g", "reason": "Hard-coded domain; ensure intended / configurable" },
    { "pattern": "app\\.reflectt\\.ai", "flags": "g", "reason": "Hard-coded domain; ensure intended / configurable" }
  ],
  "allow": [
    {
      "pathPattern": "^README\\.md$",
      "pattern": "reflectt\\.ai",
      "reason": "Allowed in README marketing context"
    },
    {
      "pathPattern": "^src/dashboard\\.ts$",
      "pattern": "(?:app\\.|docs\\.)?reflectt\\.ai",
      "reason": "Public-facing URLs in dashboard copy (cloud signup, docs links)"
    },
    {
      "pathPattern": "^src/index\\.ts$",
      "pattern": "(?:app\\.)?reflectt\\.ai",
      "reason": "Public-facing URL in first-run terminal guidance for new users"
    }
  ]
}
